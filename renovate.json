{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Formula/kxd.rb$/"],
      "matchStrings": ["ver = \"(?<currentValue>.*)\""],
      "depNameTemplate": "radiusmethod/kxd",
      "datasourceTemplate": "github-releases"
    }
  ]
}
